PORT=5000

# PostgreSQL (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"

# Auth
JWT_SECRET=your_jwt_secret_here
OTP_SECRET=optional_otp_secret_here
OTP_DEBUG_RETURN=true

# Admin login (backend admin panel)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=your_admin_password_here

# SMTP (for email OTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_pass
SMTP_FROM=Support <support@example.com>
MAIL_FROM_NAME=StudentPath Support

# SMS webhook (for mobile OTP)
# Your webhook should accept POST JSON: { "to": "...", "message": "..." }
SMS_WEBHOOK_URL=
SMS_WEBHOOK_TOKEN=

# Google OAuth (backend verification / token flows)
GOOGLE_CLIENT_ID=your_google_client_id_here

NODE_ENV=development
